# Local contributors can run the public board without credentials.
USE_SAMPLE_DATA=true

# Shared Google Sheets configuration (required when USE_SAMPLE_DATA is false)
GOOGLE_SHEET_ID=your_spreadsheet_id
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Next.js admin -> GitHub Actions dispatch (server-only)
GITHUB_OWNER=your_github_username
GITHUB_REPO=job-client
GITHUB_WORKFLOW_ID=daily-update.yml
GITHUB_ACTIONS_TOKEN=github_pat_replace_me

# Next.js admin authentication (server-only)
ADMIN_PASSWORD_HASH=replace_with_a_password_hash
SESSION_SECRET=replace_with_a_long_random_secret
